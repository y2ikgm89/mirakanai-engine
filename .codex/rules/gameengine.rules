# Narrow Codex command policy for MIRAIKANAI Engine.
# Rule edits may need policy reload or a new session before they affect commands.

prefix_rule(
    pattern = ["pwsh", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", ["tools/bootstrap-deps.ps1", "tools/build-mobile-android.ps1", "tools/check-android-release-package.ps1", "tools/smoke-android-package.ps1", "tools/build-mobile-apple.ps1", "tools/smoke-ios-package.ps1"]],
    decision = "prompt",
    justification = "Dependency bootstrap and mobile lanes can touch user caches, SDKs, emulators, or signing material.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/bootstrap-deps.ps1",
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/smoke-android-package.ps1 -Game sample_headless -Configuration Release -SkipBuild -StartEmulator -AvdName Mirakanai_API36",
    ],
    not_match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate.ps1",
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/check-ai-integration.ps1",
    ],
)

prefix_rule(
    pattern = ["git", ["reset", "restore", "checkout", "clean"]],
    decision = "prompt",
    justification = "Review worktree-mutating Git commands before user changes are overwritten.",
    match = [
        "git reset --hard",
        "git restore .",
        "git checkout -- engine/core/include/mirakana/core/application.hpp",
        "git clean -fdx",
    ],
    not_match = [
        "git commit -m \"Implement focused slice\"",
        "git push -u origin codex/example",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "worktree", ["remove", "prune", "repair"]],
    decision = "prompt",
    justification = "Worktree cleanup mutates shared Git administrative state.",
    match = [
        "git worktree remove .worktrees/codex/example",
        "git worktree prune",
    ],
    not_match = [
        "git worktree list",
        "git worktree add ../GameEngine-example -b codex/example",
    ],
)

prefix_rule(
    pattern = ["git", "clone"],
    decision = "prompt",
    justification = "Publication temp clones bypass the repository preflight path; use tools/check-publication-preflight.ps1 in the task worktree.",
    match = [
        "git clone https://github.com/y2ikgm89/mirakanai-engine.git out/publication-clone/example",
    ],
    not_match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/check-publication-preflight.ps1",
        "git ls-remote --heads origin codex/example",
    ],
)

prefix_rule(
    pattern = ["pwsh", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "tools/post-merge-task-cleanup.ps1"],
    decision = "allow",
    justification = "Preferred post-merge wrapper verifies head reachability, then delegates to guarded remove-merged-worktree cleanup.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/post-merge-task-cleanup.ps1 -WorktreePath .worktrees/codex/example -HeadRefOid 0123456789abcdef0123456789abcdef01234567",
    ],
    not_match = [
        "git worktree remove .worktrees/codex/example",
        "Remove-Item -LiteralPath .worktrees/codex/example -Recurse -Force",
    ],
)

prefix_rule(
    pattern = ["pwsh", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "tools/remove-merged-worktree.ps1"],
    decision = "allow",
    justification = "Lower-level guarded cleanup verifies Git worktree porcelain records, clean status, branch ancestry, and reparse points before removal.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/remove-merged-worktree.ps1 -WorktreePath .worktrees/codex/example -BaseRef origin/main -BaseBranch main -Remote origin -DeleteLocalBranch",
    ],
    not_match = [
        "git worktree remove .worktrees/codex/example",
        "Remove-Item -LiteralPath .worktrees/codex/example -Recurse -Force",
    ],
)

prefix_rule(
    pattern = ["pwsh", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "tools/check-publication-preflight.ps1"],
    decision = "allow",
    justification = "Guarded GitHub Flow preflight verifies current user, linked-worktree index.lock ACL, remote reachability, gh auth, and optional PR state.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/check-publication-preflight.ps1",
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/check-publication-preflight.ps1 -PullRequest 268 -RequireClean",
    ],
    not_match = [
        "git push -u origin codex/example",
        "gh pr create --base main --head codex/example --title \"Implement focused slice\" --body \"Validation: validate.ps1 passed\"",
    ],
)

prefix_rule(
    pattern = ["pwsh", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "tools/ready-task-pr.ps1"],
    decision = "allow",
    justification = "Guarded PR ready conversion verifies branch, PR state, merge state, checks, and PR Gate before gh pr ready.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/ready-task-pr.ps1 -PullRequest 120 -ExpectedBase main",
    ],
    not_match = [
        "gh pr ready 120",
        "gh pr edit --base main",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", ["main", "master"]],
    decision = "forbidden",
    justification = "Direct pushes to default or protected branches are outside GitHub Flow.",
    match = [
        "git push origin main",
        "git push origin master",
    ],
    not_match = [
        "git push -u origin codex/example",
        "git push origin codex/example",
    ],
)

prefix_rule(
    pattern = ["git", "push", ["-u", "--set-upstream"], "origin", ["main", "master"]],
    decision = "forbidden",
    justification = "Default-branch upstream pushes bypass GitHub Flow.",
    match = [
        "git push -u origin main",
        "git push --set-upstream origin master",
    ],
    not_match = [
        "git push -u origin codex/example",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", ["HEAD:main", "HEAD:master"]],
    decision = "forbidden",
    justification = "Pushing HEAD to the default branch bypasses GitHub Flow.",
    match = [
        "git push origin HEAD:main",
        "git push origin HEAD:master",
    ],
    not_match = [
        "git push origin HEAD:codex/example",
    ],
)

prefix_rule(
    pattern = ["git", "push", ["--force", "--force-with-lease"], "origin", ["main", "master"]],
    decision = "forbidden",
    justification = "History rewriting the default branch must be blocked.",
    match = [
        "git push --force origin main",
        "git push --force-with-lease origin master",
    ],
    not_match = [
        "git push --force-with-lease origin codex/example",
    ],
)

prefix_rule(
    pattern = ["git", "push", ["--force", "--force-with-lease"]],
    decision = "prompt",
    justification = "History rewriting pushes need branch-ownership review.",
    match = [
        "git push --force",
        "git push --force-with-lease origin codex/example",
    ],
    not_match = [
        "git push origin codex/example",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "allow",
    justification = "Task-owned PR creation is allowed after validation checkpoints.",
    match = [
        "gh pr create --base main --head codex/example --title \"Implement focused slice\" --body \"Validation: validate.ps1 passed\"",
        "gh pr create --draft --base main --head codex/example --title \"Implement focused slice\" --body \"Validation: focused checks passed\"",
    ],
    not_match = [
        "gh pr edit --base main",
        "gh pr ready",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "view"],
    decision = "allow",
    justification = "Read-only PR state inspection is required before auto-merge registration.",
    match = [
        "gh pr view --json state,isDraft,baseRefName,headRefName,headRefOid,mergeable,mergeStateStatus,reviewDecision,statusCheckRollup,autoMergeRequest,url",
        "gh pr view 4 --json state,isDraft,baseRefName,headRefName,headRefOid,mergeable,mergeStateStatus,reviewDecision,statusCheckRollup,autoMergeRequest,url",
    ],
    not_match = [
        "gh pr edit --base main",
        "gh pr merge --merge --delete-branch",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "merge", "--auto", "--merge", "--match-head-commit"],
    decision = "allow",
    justification = "Register auto-merge only after PR preflight; branch cleanup prefers tools/post-merge-task-cleanup.ps1.",
    match = [
        "gh pr merge --auto --merge --match-head-commit 0123456789abcdef0123456789abcdef01234567",
        "gh pr merge --auto --merge --match-head-commit 0123456789abcdef0123456789abcdef01234567 42",
    ],
    not_match = [
        "gh pr merge --auto --merge --delete-branch",
        "gh pr merge --merge --delete-branch",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "merge", ["--merge", "--squash", "--rebase", "--admin"]],
    decision = "prompt",
    justification = "Immediate PR merges are outside the unattended auto-merge path.",
    match = [
        "gh pr merge --merge --delete-branch",
        "gh pr merge --admin --merge --delete-branch",
    ],
    not_match = [
        "gh pr merge --auto --merge --match-head-commit 0123456789abcdef0123456789abcdef01234567",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["edit", "ready", "close", "reopen"]],
    decision = "prompt",
    justification = "PR state changes outside create plus auto-merge need review.",
    match = [
        "gh pr edit --base main",
        "gh pr ready",
        "gh pr close",
    ],
    not_match = [
        "gh pr view --json url,state",
        "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/ready-task-pr.ps1 -PullRequest 120 -ExpectedBase main",
    ],
)

prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "Use reviewed PowerShell Remove-Item with resolved paths, or git rm for tracked files.",
    match = [
        "rm -rf out",
        "rm -rf .",
    ],
    not_match = [
        "git rm -r games/example",
    ],
)

prefix_rule(
    pattern = ["Remove-Item"],
    decision = "prompt",
    justification = "PowerShell deletion needs resolved-path and scope review.",
    match = [
        "Remove-Item -LiteralPath out -Recurse -Force",
    ],
    not_match = [
        "Get-Item -LiteralPath out",
    ],
)

prefix_rule(
    pattern = [["curl", "wget", "Invoke-WebRequest", "Invoke-RestMethod"]],
    decision = "prompt",
    justification = "Network downloads need source-trust and license review.",
    match = [
        "Invoke-WebRequest -Uri https://example.com/file.txt -OutFile file.txt",
        "Invoke-RestMethod -Uri https://example.com/api",
    ],
    not_match = [
        "Get-Command Invoke-WebRequest",
    ],
)

prefix_rule(
    pattern = [["Add-WindowsCapability", "dism", "msiexec"]],
    decision = "prompt",
    justification = "Host diagnostic/toolchain servicing modifies Windows state.",
    match = [
        "Add-WindowsCapability -Online -Name Tools.Graphics.DirectX~~~~0.0.1.0",
        "msiexec /qn /p Windows_ADK_10.1.26100.2454_Update_KB5079391.msp",
    ],
    not_match = [
        "Get-Command cdb",
    ],
)
