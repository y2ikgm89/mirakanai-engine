{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "normalized-configure-environment",
      "hidden": true,
      "environment": {
        "PATH": "$penv{PATH}",
        "Path": null
      }
    },
    {
      "name": "dev-core",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/dev",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "dev-windows-gui",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "MK_ENABLE_DESKTOP_GUI": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "dev",
      "displayName": "Developer build",
      "binaryDir": "${sourceDir}/out/build/dev",
      "inherits": ["normalized-configure-environment", "dev-core", "dev-windows-gui"],
      "cacheVariables": {
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "cpp23-eval",
      "displayName": "C++23 verification build",
      "binaryDir": "${sourceDir}/out/build/cpp23-eval",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "cpp23-release-eval",
      "displayName": "C++23 release package verification build",
      "binaryDir": "${sourceDir}/out/build/cpp23-release-preset-eval",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "desktop-runtime",
      "displayName": "Desktop runtime build",
      "binaryDir": "${sourceDir}/out/build/desktop-runtime",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "MK_ENABLE_DESKTOP_RUNTIME": "ON",
        "MK_ENABLE_DESKTOP_GUI": "OFF",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "desktop-gui",
      "displayName": "Desktop GUI build",
      "binaryDir": "${sourceDir}/out/build/desktop-gui",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "MK_ENABLE_DESKTOP_GUI": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
