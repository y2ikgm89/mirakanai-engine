      "displayName": "Asset importer dependency build",
      "binaryDir": "${sourceDir}/out/build/asset-importers",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "MK_ENABLE_ASSET_IMPORTERS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "cpp23-desktop-gui-eval",
      "displayName": "C++23 desktop GUI verification build",
      "binaryDir": "${sourceDir}/out/build/cpp23-desktop-gui-eval",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "MK_ENABLE_DESKTOP_GUI": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "release",
      "displayName": "Release package build",
      "binaryDir": "${sourceDir}/out/build/release",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "desktop-runtime-release",
      "displayName": "Desktop runtime release package build",
      "binaryDir": "${sourceDir}/out/build/desktop-runtime-release",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "MK_ENABLE_DESKTOP_RUNTIME": "ON",
        "MK_ENABLE_DESKTOP_GUI": "OFF",
        "MK_REQUIRE_DESKTOP_RUNTIME_DXIL": "OFF",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "clang-asan-ubsan",
      "displayName": "Clang Address/Undefined sanitizer build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/clang-asan-ubsan",
      "inherits": "normalized-configure-environment",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "MK_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "ci-linux-clang",
      "displayName": "CI Linux Clang build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/ci-linux-clang",
      "inherits": "normalized-configure-environment",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "ON",
        "MK_ENABLE_IMPORT_STD": "ON",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "ci-linux-tidy",
      "displayName": "CI Linux clang-tidy analysis",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/ci-linux-tidy",
      "inherits": "normalized-configure-environment",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "OFF",
        "MK_ENABLE_IMPORT_STD": "OFF",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview"
      }
    },
    {
      "name": "coverage",
      "displayName": "Linux GCC coverage build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/coverage",
      "inherits": "normalized-configure-environment",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "MK_CXX_STANDARD": "23",
        "MK_ENABLE_CXX_MODULE_SCANNING": "OFF",
        "MK_ENABLE_IMPORT_STD": "OFF",
        "MK_MSVC_CXX23_STANDARD_OPTION": "/std:c++23preview",
        "CMAKE_CXX_FLAGS": "--coverage",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage"
      }
    },
    {
      "name": "ci-macos-appleclang",
      "displayName": "CI macOS AppleClang build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/ci-macos-appleclang",
