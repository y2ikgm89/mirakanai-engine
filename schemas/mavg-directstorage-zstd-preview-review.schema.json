          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9._:/-]+$"
        },
        "feature": {
          "enum": [
            "zstd_codec",
            "gacl_shuffle_transform",
            "creator_id",
            "preview_known_issue"
          ]
        },
        "officialSourceId": {
          "enum": [
