{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gameengine/game-agent.schema.json",
  "title": "GameEngine Game Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "displayName",
    "language",
    "entryPoint",
    "target",
    "engineModules",
    "aiWorkflow",
    "gameplayContract",
    "backendReadiness",
    "importerRequirements",
    "packagingTargets",
    "validationRecipes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "const": "C++23"
    },
    "entryPoint": {
      "type": "string"
    },
    "target": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "engineModules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "aiWorkflow": {
      "type": "object",
      "required": ["spec", "validate", "allowedEditRoots"],
      "additionalProperties": false,
      "properties": {
        "spec": {
          "type": "string",
          "minLength": 1
        },
        "validate": {
          "type": "string",
          "minLength": 1
        },
        "allowedEditRoots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/])).+$"
          }
        },
        "gameDesignSpec": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "capabilityId",
            "designId",
            "gameplayFamily",
            "template",
            "camera",
            "inputMap",
            "coreLoop",
            "sceneList",
            "assetRequests",
            "systems",
            "packageTargets",
            "validationRecipeIds",
            "qualityGates",
            "unsupportedClaims"
          ],
          "properties": {
            "schemaVersion": {
              "type": "integer",
              "const": 1
            },
            "capabilityId": {
              "type": "string",
              "const": "ai-game-design-spec-v1"
            },
            "designId": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*$"
            },
            "gameplayFamily": {
              "type": "string",
              "enum": [
                "headless-validation",
                "desktop-runtime-package",
                "desktop-runtime-cooked-scene",
                "desktop-runtime-material-shader",
                "2d-desktop-runtime-package",
                "3d-playable-desktop-package"
              ]
            },
            "template": {
              "type": "string",
              "enum": [
                "Headless",
                "DesktopRuntimePackage",
                "DesktopRuntimeCookedScenePackage",
                "DesktopRuntimeMaterialShaderPackage",
                "DesktopRuntime2DPackage",
                "DesktopRuntime3DPackage"
              ]
            },
            "camera": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "primary"],
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["none", "fixed-2d", "side-view-2d", "perspective-3d", "orbit-3d"]
                },
                "primary": {
                  "type": "string",
                  "minLength": 1
                },
                "notes": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "inputMap": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["action", "defaultBinding", "purpose"],
                "properties": {
                  "action": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "defaultBinding": {
                    "type": "string",
                    "minLength": 1
                  },
                  "purpose": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "coreLoop": {
              "type": "object",
              "additionalProperties": false,
              "required": ["objective", "playerActions", "feedback", "winState", "failState", "restart"],
              "properties": {
                "objective": {
                  "type": "string",
                  "minLength": 1
                },
                "playerActions": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "feedback": {
                  "type": "string",
                  "minLength": 1
                },
                "winState": {
                  "type": "string",
                  "minLength": 1
                },
                "failState": {
                  "type": "string",
                  "minLength": 1
                },
                "restart": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "sceneList": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "kind", "path", "purpose"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "kind": {
                    "type": "string",
                    "enum": ["config", "scene", "package-index", "source-scene", "source-prefab"]
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/])).+$"
                  },
                  "purpose": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "assetRequests": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "kind", "purpose", "delivery"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "config",
                      "texture",
                      "sprite-atlas",
                      "tilemap",
                      "mesh",
                      "material",
                      "shader",
                      "audio",
                      "ui-atlas",
                      "scene",
                      "physics-collision",
                      "animation"
                    ]
                  },
                  "purpose": {
                    "type": "string",
                    "minLength": 1
                  },
                  "delivery": {
                    "type": "string",
                    "enum": ["runtime-package-file", "reviewed-source-authoring", "host-built-shader-artifact", "first-party-placeholder"]
                  }
                }
              }
            },
            "systems": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "packageTargets": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "validationRecipeIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$"
              }
            },
            "qualityGates": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "evidence", "recipeIds"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "evidence": {
                    "type": "string",
                    "minLength": 1
                  },
                  "recipeIds": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$"
                    }
                  }
                }
              }
            },
            "unsupportedClaims": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "engine-internal-edits",
                  "native-handles",
                  "middleware-contracts",
                  "unreviewed-external-assets",
                  "arbitrary-shell",
                  "broad-commercial-quality",
                  "runtime-source-parsing",
                  "renderer-rhi-residency",
                  "metal-readiness"
                ]
              }
            }
          }
        },
        "contentMutationLedger": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "capabilityId",
            "ledgerId",
            "aiOwnedSourceRoots",
            "generatedFiles",
            "reviewedCommandSurfaces",
            "forbiddenSharedPaths",
            "remediationActions"
          ],
          "properties": {
            "schemaVersion": {
              "type": "integer",
              "const": 1
            },
            "capabilityId": {
              "type": "string",
              "const": "ai-safe-content-mutation-ledger-v1"
            },
            "ledgerId": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*-ai-mutation-ledger$"
            },
            "aiOwnedSourceRoots": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "path", "allowedOperations", "reviewedCommandSurfaceIds", "evidence"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "path": {
                    "type": "string",
                    "pattern": "^games/[a-z][a-z0-9_]*/(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+$|^games/[a-z][a-z0-9_]*$"
                  },
                  "allowedOperations": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": ["create", "modify"]
                    }
                  },
                  "reviewedCommandSurfaceIds": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$"
                    }
                  },
                  "evidence": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "generatedFiles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "path", "generatedBy", "reviewedCommandSurfaceId", "updatePolicy"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "path": {
                    "type": "string",
                    "pattern": "^games/[a-z][a-z0-9_]*/(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+$"
                  },
                  "generatedBy": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reviewedCommandSurfaceId": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "updatePolicy": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "reviewedCommandSurfaces": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "mode", "command", "allowedPathRoots", "validationRecipeIds", "unsupportedActions"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["dry-run-apply", "review-only"]
                  },
                  "command": {
                    "type": "string",
                    "minLength": 1
                  },
                  "allowedPathRoots": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "pattern": "^games/[a-z][a-z0-9_]*/(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+$|^games/[a-z][a-z0-9_]*$"
                    }
                  },
                  "validationRecipeIds": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$"
                    }
                  },
                  "unsupportedActions": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "allOf": [
                      {
                        "contains": {
                          "const": "arbitrary-shell"
                        }
                      },
                      {
                        "contains": {
                          "const": "engine-internal-edits"
                        }
                      },
                      {
                        "contains": {
                          "const": "native-handles"
                        }
                      },
                      {
                        "contains": {
                          "const": "middleware-contracts"
                        }
                      },
                      {
                        "contains": {
                          "const": "unreviewed-external-assets"
                        }
                      },
                      {
                        "contains": {
                          "const": "cooked-package-mutation"
                        }
                      },
                      {
                        "contains": {
                          "const": "renderer-rhi-residency"
                        }
                      },
                      {
                        "contains": {
                          "const": "broad-commercial-quality"
                        }
                      }
                    ],
                    "items": {
                      "type": "string",
                      "enum": [
                        "arbitrary-shell",
                        "engine-internal-edits",
                        "native-handles",
                        "middleware-contracts",
                        "unreviewed-external-assets",
                        "cooked-package-mutation",
                        "renderer-rhi-residency",
                        "broad-commercial-quality"
                      ]
                    }
                  }
                }
              }
            },
            "forbiddenSharedPaths": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "path", "reason"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+$"
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "remediationActions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "trigger", "reviewedCommandSurfaceId", "expectedResult", "validationRecipeIds"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "trigger": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reviewedCommandSurfaceId": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                  },
                  "expectedResult": {
                    "type": "string",
                    "minLength": 1
                  },
                  "validationRecipeIds": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$"
                    }
                  }
                }
              }
            }
          }
        },
        "engineCapabilityHandoffs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "handoffId",
              "requestedCapabilityId",
              "blockedFeatureId",
              "currentWorkaround",
              "affectedGameFiles",
              "desiredPublicContract",
              "requiredEvidenceIds"
            ],
            "properties": {
              "handoffId": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$"
              },
              "requestedCapabilityId": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*-v[0-9]+$"
              },
              "blockedFeatureId": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$"
              },
              "currentWorkaround": {
                "type": "string",
                "minLength": 1
              },
              "affectedGameFiles": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^games/[a-z][a-z0-9_]*/(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+$"
                }
              },
              "desiredPublicContract": {
                "type": "string",
                "minLength": 1
              },
              "requiredEvidenceIds": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9-]*$"
                }
              }
            }
          }
        }
      }
    },
    "gameplayContract": {
      "type": "object",
      "required": ["currentRuntime"]
    },
    "backendReadiness": {
      "type": "object",
      "required": ["platform", "graphics", "audio", "ui"]
    },
    "importerRequirements": {
      "type": "object",
      "required": ["sourceFormats", "cookedOnlyRuntime", "externalImportersRequired"]
    },
    "packagingTargets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "runtimePackageFiles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|/)\\.\\.($|/)).+"
      }
    },
    "runtimeSceneValidationTargets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "packageIndexPath", "sceneAssetKey"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "packageIndexPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.geindex$"
          },
          "sceneAssetKey": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(^|/)\\.\\.($|/))(?!.*\\s).+$"
          },
          "contentRoot": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+$"
          },
          "validateAssetReferences": {
            "type": "boolean"
          },
          "requireUniqueNodeNames": {
            "type": "boolean"
          }
        }
      }
    },
    "materialShaderAuthoringTargets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "sourceMaterialPath", "runtimeMaterialPath", "packageIndexPath", "shaderSourcePaths"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "sourceMaterialPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.material$"
          },
          "runtimeMaterialPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.material$"
          },
          "packageIndexPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.geindex$"
          },
          "shaderSourcePaths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.hlsl$"
            }
          },
          "d3d12ShaderArtifactPaths": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.dxil$"
            }
          },
          "vulkanShaderArtifactPaths": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.spv$"
            }
          },
          "validateMaterialTextures": {
            "type": "boolean"
          },
          "validateShaderArtifacts": {
            "type": "boolean"
          }
        }
      }
    },
    "atlasTilemapAuthoringTargets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "id",
          "packageIndexPath",
          "tilemapPath",
          "atlasTexturePath",
          "tilemapAssetKey",
          "atlasTextureAssetKey",
          "mode",
          "sourceDecoding",
          "atlasPacking",
          "nativeGpuSpriteBatching"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "packageIndexPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.geindex$"
          },
          "tilemapPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.tilemap$"
          },
          "atlasTexturePath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!games/)(?!.*(^|[\\\\/])\\.\\.($|[\\\\/]))(?!.*;).+\\.geasset$"
          },
          "tilemapAssetKey": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(^|/)\\.\\.($|/))(?!.*\\s).+$"
          },
          "atlasTextureAssetKey": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(^|/)\\.\\.($|/))(?!.*\\s).+$"
          },
          "mode": {
            "type": "string",
            "const": "deterministic-package-data"
          },
          "sourceDecoding": {
            "type": "string",
            "const": "unsupported"
          },
          "atlasPacking": {
            "type": "string",
            "const": "unsupported"
          },
          "nativeGpuSpriteBatching": {
            "type": "string",
