{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gameengine/2d-commercial-official-source-summary.schema.json",
  "title": "GameEngine 2D Commercial Official Source Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "validation_recipe",
    "generated_utc",
    "source_policy",
    "legal_advice",
    "external_engine_material_selected",
    "official_source_count",
    "reference_source_count",
    "rejected_external_material",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "const": "GameEngine.TwoDCommercialOfficialSourceSummary.v1" },
    "validation_recipe": { "const": "2d-commercial-clean-room-review-input" },
    "generated_utc": {
      "type": "string",
      "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "source_policy": { "const": "official-public-documentation-category-research-only" },
    "legal_advice": { "const": false },
    "external_engine_material_selected": { "const": false },
    "official_source_count": { "type": "integer", "minimum": 10 },
    "reference_source_count": { "type": "integer", "minimum": 3 },
    "rejected_external_material": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "prefixItems": [
        { "const": "external_engine_code" },
        { "const": "external_engine_sample" },
        { "const": "external_engine_shader" },
        { "const": "external_engine_asset" },
        { "const": "external_engine_trademark" },
        { "const": "external_engine_ui_expression" },
        { "const": "external_engine_project_import" },
        { "const": "external_engine_schema" },
        { "const": "external_engine_api" },
        { "const": "compatibility_claim" },
        { "const": "equivalence_claim" },
        { "const": "parity_claim" }
      ]
    },
    "non_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "commercial_ready", "legal_approval", "external_engine_parity" ],
      "properties": {
        "commercial_ready": { "const": false },
        "legal_approval": { "const": false },
        "external_engine_parity": { "const": false }
      }
    }
  }
}
