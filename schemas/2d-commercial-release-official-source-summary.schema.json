{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gameengine/2d-commercial-release-official-source-summary.schema.json",
  "title": "GameEngine 2D Commercial Release Official Source Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "claim_id",
    "validation_recipe",
    "legal_advice",
    "official_source_rows",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "claim_id": { "const": "2d-commercial-release-legal-gate-v1" },
    "validation_recipe": { "const": "2d-commercial-release-legal-review-input" },
    "legal_advice": { "const": false },
    "official_source_rows": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "url",
          "use",
          "ready",
          "official",
          "public_docs_only",
          "implementation_input",
          "copied_expression_allowed"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": [
              "microsoft_msix_signing",
              "apple_notarization_distribution",
              "android_app_signing",
              "repository_clean_room_ledger",
              "repository_legal_policy"
            ]
          },
          "url": { "type": "string", "minLength": 1 },
          "use": { "type": "string", "minLength": 1 },
          "ready": { "const": true },
          "official": { "const": true },
          "public_docs_only": { "const": true },
          "implementation_input": { "const": false },
          "copied_expression_allowed": { "const": false }
        }
      }
    },
    "non_claims": {
      "type": "object",
      "required": [ "legal_approval", "compatibility", "parity" ],
      "properties": {
        "legal_approval": { "const": false },
        "compatibility": { "const": false },
        "parity": { "const": false }
      }
    }
  }
}
