{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gameengine/mavg-broad-optimization-artifacts.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "rows"
  ],
  "properties": {
    "schema_version": { "const": "GameEngine.MavgBroadOptimizationArtifacts.v1" },
    "task_id": { "const": "mavg-broad-optimization-evidence-v1" },
    "rows": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/evidenceRow" }
    }
  },
  "$defs": {
    "evidenceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "vendor",
        "workload",
        "profiler_tool",
        "package_hash_sha256",
        "camera_script_id",
        "host_class",
        "adapter_id",
        "driver_version",
        "profiler_tool_version",
        "profiler_tool_support_source_id",
        "profiler_artifact_id",
        "profiler_artifact_hash_sha256",
        "baseline",
        "optimized",
        "profiler_capture_overhead_basis_points",
        "reviewed",
        "official_profiler_tool",
        "profiler_tool_currently_supported",
        "internal_engine_counters_ready",
        "external_profiler_artifact_ready",
        "first_party_package",
        "cpu_timeline_available",
        "gpu_timeline_available",
        "io_timeline_available",
        "memory_timeline_available",
        "queue_timeline_available",
        "no_profiler_timestamp_overflow",
        "representative_capture",
        "synthetic_only",
        "native_handles_exposed",
        "claims_broad_engine_ready",
        "claims_broad_backend_readiness"
      ],
      "properties": {
        "backend": { "type": "string", "enum": ["d3d12", "vulkan", "metal_apple_host"] },
        "vendor": { "type": "string", "enum": ["nvidia", "amd", "intel", "apple"] },
        "workload": { "type": "string", "enum": ["mavg_stress_package", "first_party_gameplay_package"] },
        "profiler_tool": {
          "type": "string",
          "enum": [
            "pix_timing_capture",
            "nsight_graphics_gpu_trace",
            "radeon_gpu_profiler",
            "intel_gpa",
            "apple_metal_tools"
          ]
        },
        "package_hash_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "camera_script_id": { "type": "string", "minLength": 1 },
        "host_class": { "type": "string", "minLength": 1 },
        "adapter_id": { "type": "string", "minLength": 1 },
        "driver_version": { "type": "string", "minLength": 1 },
        "profiler_tool_version": { "type": "string", "minLength": 1 },
        "profiler_tool_support_source_id": { "type": "string", "minLength": 1 },
        "profiler_artifact_id": { "type": "string", "minLength": 1 },
        "profiler_artifact_hash_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "baseline": { "$ref": "#/$defs/metrics" },
        "optimized": { "$ref": "#/$defs/metrics" },
        "profiler_capture_overhead_basis_points": { "type": "integer", "minimum": 0, "maximum": 500 },
        "reviewed": { "type": "boolean" },
        "official_profiler_tool": { "type": "boolean" },
        "profiler_tool_currently_supported": { "type": "boolean" },
        "internal_engine_counters_ready": { "type": "boolean" },
        "external_profiler_artifact_ready": { "type": "boolean" },
        "first_party_package": { "type": "boolean" },
        "cpu_timeline_available": { "type": "boolean" },
        "gpu_timeline_available": { "type": "boolean" },
        "io_timeline_available": { "type": "boolean" },
        "memory_timeline_available": { "type": "boolean" },
        "queue_timeline_available": { "type": "boolean" },
        "no_profiler_timestamp_overflow": { "type": "boolean" },
        "representative_capture": { "type": "boolean" },
        "synthetic_only": { "type": "boolean" },
        "native_handles_exposed": { "type": "boolean" },
        "claims_broad_engine_ready": { "type": "boolean" },
        "claims_broad_backend_readiness": { "type": "boolean" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_frame_p50_us",
        "cpu_frame_p95_us",
        "cpu_frame_p99_us",
        "cpu_streaming_jobs_p95_us",
        "gpu_frame_p50_us",
        "gpu_frame_p95_us",
        "gpu_frame_p99_us",
        "gpu_upload_p95_us",
        "gpu_draw_dispatch_p95_us",
        "vram_peak_bytes",
        "resident_page_bytes",
        "page_fault_count",
        "io_bytes_per_second",
        "io_request_count",
        "heap_allocation_count",
        "replay_hash"
      ],
      "properties": {
        "cpu_frame_p50_us": { "type": "integer", "minimum": 1 },
        "cpu_frame_p95_us": { "type": "integer", "minimum": 1 },
        "cpu_frame_p99_us": { "type": "integer", "minimum": 1 },
        "cpu_streaming_jobs_p95_us": { "type": "integer", "minimum": 1 },
        "gpu_frame_p50_us": { "type": "integer", "minimum": 1 },
        "gpu_frame_p95_us": { "type": "integer", "minimum": 1 },
        "gpu_frame_p99_us": { "type": "integer", "minimum": 1 },
        "gpu_upload_p95_us": { "type": "integer", "minimum": 1 },
        "gpu_draw_dispatch_p95_us": { "type": "integer", "minimum": 1 },
        "vram_peak_bytes": { "type": "integer", "minimum": 1 },
        "resident_page_bytes": { "type": "integer", "minimum": 1 },
        "page_fault_count": { "type": "integer", "minimum": 0 },
        "io_bytes_per_second": { "type": "integer", "minimum": 1 },
        "io_request_count": { "type": "integer", "minimum": 1 },
        "heap_allocation_count": { "type": "integer", "minimum": 1 },
        "replay_hash": { "type": "string", "minLength": 1 }
      }
    }
  }
}
