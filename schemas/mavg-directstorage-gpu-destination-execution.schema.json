{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mirakanai.local/GameEngine.MavgDirectStorageGpuDestinationExecutionEvidence.v1.schema.json",
  "title": "GameEngine.MavgDirectStorageGpuDestinationExecutionEvidence.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "planId",
    "sourceRows",
    "evidenceRows",
    "summary"
  ],
  "properties": {
    "schema": {
      "const": "GameEngine.MavgDirectStorageGpuDestinationExecutionEvidence.v1"
    },
    "planId": {
      "const": "mavg-directstorage-gpu-destination-execution-evidence-v1"
    },
    "sourceRows": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/sourceRow"
      }
    },
    "evidenceRows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceRow"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "sourceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "url",
        "reviewed",
        "notes"
      ],
      "properties": {
        "sourceId": {
          "enum": [
            "microsoft-directstorage-api-downloads",
            "microsoft-directstorage-1.3-enqueue-requests",
            "microsoft-directstorage-1.3-multiple-subresources-range",
            "microsoft-directstorage-developer-guidance",
            "microsoft-directstorage-1.4-zstd-preview",
            "microsoft-d3d12-resource-barriers"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "reviewed": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidenceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rowId",
        "officialSourceId",
        "sdkPackageVersion",
        "destination",
        "retainedArtifactId",
        "retainedArtifactSha256",
        "requestedBytes",
        "completedBytes",
        "firstSubresource",
        "numSubresources",
        "reviewed",
        "ready",
        "stableDirectStorage13Selected",
        "directStorage14PreviewSelected",
        "queueDeviceBound",
        "destinationResourceDeviceMatchesQueueDevice",
        "enqueueRequestsUsed",
        "d3d12FenceSynchronizationUsed",
        "destinationResourceStateCommon",
        "requestCompleted",
        "statusArraySuccess",
        "readbackHashReady",
        "packageVisibleOutputReady",
        "claims"
      ],
      "properties": {
        "rowId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9._:/-]+$"
        },
        "officialSourceId": {
          "enum": [
            "microsoft-directstorage-api-downloads",
            "microsoft-directstorage-1.3-enqueue-requests",
            "microsoft-directstorage-1.3-multiple-subresources-range",
            "microsoft-directstorage-developer-guidance",
            "microsoft-d3d12-resource-barriers"
          ]
        },
        "sdkPackageVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "destination": {
          "enum": [
            "d3d12_buffer",
            "d3d12_texture_region",
            "d3d12_multiple_subresources_range"
          ]
        },
        "retainedArtifactId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180,
          "pattern": "^[A-Za-z0-9._:/-]+$"
        },
        "retainedArtifactSha256": {
          "$ref": "#/$defs/sha256"
        },
        "requestedBytes": {
          "type": "integer",
          "minimum": 1
        },
        "completedBytes": {
          "type": "integer",
          "minimum": 1
        },
        "firstSubresource": {
          "type": "integer",
          "minimum": 0
        },
        "numSubresources": {
          "type": "integer",
          "minimum": 0
        },
        "reviewed": {
          "type": "boolean"
        },
        "ready": {
          "type": "boolean"
        },
        "stableDirectStorage13Selected": {
          "type": "boolean"
        },
        "directStorage14PreviewSelected": {
          "const": false
        },
        "queueDeviceBound": {
          "type": "boolean"
        },
        "destinationResourceDeviceMatchesQueueDevice": {
          "type": "boolean"
        },
        "enqueueRequestsUsed": {
          "type": "boolean"
        },
        "d3d12FenceSynchronizationUsed": {
          "type": "boolean"
        },
        "destinationResourceStateCommon": {
          "type": "boolean"
        },
        "requestCompleted": {
          "type": "boolean"
        },
        "statusArraySuccess": {
          "type": "boolean"
        },
        "readbackHashReady": {
          "type": "boolean"
        },
        "packageVisibleOutputReady": {
          "type": "boolean"
        },
        "claims": {
          "$ref": "#/$defs/claims"
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gdeflateExecutionReady",
        "zstdPreviewReady",
        "nativeHandlesExposed",
        "performanceReady",
        "packageVisibleBackendReadinessReady",
        "broadCpuGpuMemoryOptimizationReady",
        "naniteCompatible",
        "naniteEquivalent",
        "naniteSuperior",
        "unityUnrealGodotCompatibility"
      ],
      "properties": {
        "gdeflateExecutionReady": {
          "const": false
        },
        "zstdPreviewReady": {
          "const": false
        },
        "nativeHandlesExposed": {
          "const": false
        },
        "performanceReady": {
          "const": false
        },
        "packageVisibleBackendReadinessReady": {
          "const": false
        },
        "broadCpuGpuMemoryOptimizationReady": {
          "const": false
        },
        "naniteCompatible": {
          "const": false
        },
        "naniteEquivalent": {
          "const": false
        },
        "naniteSuperior": {
          "const": false
        },
        "unityUnrealGodotCompatibility": {
          "const": false
        }
      }
    },
    "zeroOrOne": {
      "type": "integer",
      "enum": [
        0,
        1
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mavg_directstorage_gpu_destination_execution_ready",
        "mavg_directstorage_multiple_subresources_range_execution_ready",
        "mavg_directstorage_gdeflate_execution_ready",
        "mavg_directstorage_zstd_preview_ready",
        "mavg_directstorage_native_handles_exposed",
        "mavg_directstorage_performance_ready",
        "mavg_package_visible_backend_readiness_ready",
        "mavg_broad_cpu_gpu_memory_optimization_ready",
        "mavg_nanite_compatible",
        "mavg_nanite_equivalent",
        "mavg_nanite_superior",
        "mavg_external_engine_compatibility"
      ],
      "properties": {
        "mavg_directstorage_gpu_destination_execution_ready": {
          "$ref": "#/$defs/zeroOrOne"
        },
        "mavg_directstorage_multiple_subresources_range_execution_ready": {
          "$ref": "#/$defs/zeroOrOne"
        },
        "mavg_directstorage_gdeflate_execution_ready": {
          "const": 0
        },
        "mavg_directstorage_zstd_preview_ready": {
          "const": 0
        },
        "mavg_directstorage_native_handles_exposed": {
          "const": 0
        },
        "mavg_directstorage_performance_ready": {
          "const": 0
        },
        "mavg_package_visible_backend_readiness_ready": {
          "const": 0
        },
        "mavg_broad_cpu_gpu_memory_optimization_ready": {
          "const": 0
        },
        "mavg_nanite_compatible": {
          "const": 0
        },
        "mavg_nanite_equivalent": {
          "const": 0
        },
        "mavg_nanite_superior": {
          "const": 0
        },
        "mavg_external_engine_compatibility": {
          "const": 0
        }
      }
    }
  }
}
