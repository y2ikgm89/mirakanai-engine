{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gameengine/engine-agent.schema.json",
  "title": "GameEngine Agent Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "engine",
    "commands",
    "windowsDiagnosticsToolchain",
    "modules",
    "runtimeBackendReadiness",
    "importerCapabilities",
    "packagingTargets",
    "validationRecipes",
    "aiOperableProductionLoop",
    "aiSurfaces",
    "documentationPolicy",
    "sourcePolicy",
    "gameCodeGuidance",
    "aiDrivenGameWorkflow"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "engine": {
      "type": "object",
      "required": [
        "name",
        "stage",
        "stageStatus",
        "stageCompletion",
        "stageClosurePlan",
        "stageClosureNotes",
        "language",
        "namespace",
        "license"
      ]
    },
    "commands": {
      "type": "object",
      "required": ["validate", "prepareWorktree", "publicationPreflight", "removeMergedWorktree", "toolchainCheck", "directToolchainCheck", "build", "buildGui", "buildAssetImporters", "validateNetworkEnet", "test", "format", "formatCheck", "textFormat", "textFormatCheck", "agentContext", "agentCheck", "composeAgentManifest", "newGame"]
    },
    "windowsDiagnosticsToolchain": {
      "type": "object",
      "required": [
        "policy",
        "debuggingToolsForWindows",
        "graphicsTools",
        "pixOnWindows",
        "windowsPerformanceToolkit",
        "hostGatePolicy"
      ]
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "status", "dependencies", "publicHeaders", "purpose"]
      }
    },
    "applications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "status", "buildCommand", "dependencies", "purpose"]
      }
    },
    "runtimeBackendReadiness": {
      "type": "object",
      "required": ["graphics", "audio", "ui", "physics", "network", "platform"],
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "module", "status", "hosts", "validation", "notes"]
        }
      }
    },
    "importerCapabilities": {
      "type": "object",
      "required": [
        "runtimePolicy",
        "defaultSourceDocuments",
        "cookedArtifacts",
        "optionalDependencyFeature",
        "plannedExternalImporters"
      ]
    },
    "packagingTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "platform", "status", "command", "notes"]
      }
    },
    "validationRecipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "command", "purpose"]
      }
    },
    "aiOperableProductionLoop": {
      "$ref": "engine-agent/ai-operable-production-loop.schema.json"
    },
    "aiSurfaces": {
      "type": "object",
      "required": ["codex", "claudeCode", "cursor", "crossToolAlignment"],
      "properties": {
        "codex": {
          "type": "object"
        },
        "claudeCode": {
          "type": "object"
        },
        "cursor": {
          "type": "object"
        },
        "crossToolAlignment": {
          "type": "object",
          "required": [
            "schemaVersion",
            "capabilityId",
            "status",
            "officialDocs",
            "toolSurfaces",
            "gameOwnedWriteScopes",
            "sharedSurfaceWritePolicy",
            "reviewedCommandSurfaces",
            "validationGuards",
            "forbiddenBroadGrants",
            "requiredReadOnlyRoles",
            "unsupportedClaims"
          ],
          "properties": {
            "schemaVersion": {
              "type": "integer",
              "const": 1
            },
            "capabilityId": {
              "type": "string",
              "const": "ai-codex-claude-agent-surface-v1"
            },
            "status": {
              "type": "string",
              "const": "implemented-1x-foundation"
            },
            "officialDocs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "surface", "url", "appliesTo"]
              }
            },
            "toolSurfaces": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "object",
                "required": ["id", "instructions", "skills", "agents", "writeScope", "validationGuards"]
              }
            },
            "gameOwnedWriteScopes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "sharedSurfaceWritePolicy": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "reviewedCommandSurfaces": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "validationGuards": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "forbiddenBroadGrants": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "requiredReadOnlyRoles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "unsupportedClaims": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "documentationPolicy": {
      "type": "object",
      "required": ["preferredMcp", "useFor", "secretStorage", "doNotStoreApiKeysInRepo"]
    },
    "sourcePolicy": {
      "type": "object",
      "required": ["copyingExternalCodeWithoutExplicitLicense", "thirdPartyRecord", "licensePolicy"]
    },
    "gameCodeGuidance": {
      "type": "object",
      "required": ["entryPoint", "gameRoot", "gameManifest", "scaffoldCommand", "currentRuntime"]
    },
    "aiDrivenGameWorkflow": {
      "type": "object",
      "required": ["steps", "templateSpec", "validationScenarios", "promptPack", "sampleGame"]
    }
  }
}
