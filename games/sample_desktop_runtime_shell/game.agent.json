{
  "schemaVersion": 1,
  "name": "sample-desktop-runtime-shell",
  "displayName": "Sample Desktop Runtime Shell",
  "language": "C++23",
  "entryPoint": "games/sample_desktop_runtime_shell/main.cpp",
  "target": "sample_desktop_runtime_shell",
  "engineModules": [
    "MK_core",
    "MK_math",
    "MK_platform",
    "MK_platform_win32",
    "MK_rhi",
    "MK_renderer",
    "MK_runtime_host",
    "MK_runtime_host_win32",
    "MK_runtime_host_win32_presentation"
  ],
  "aiWorkflow": {
    "spec": "games/sample_desktop_runtime_shell/README.md",
    "validate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate-desktop-game-runtime.ps1",
    "allowedEditRoots": [
      "games/sample_desktop_runtime_shell",
      "tests"
    ]
  },
  "gameplayContract": {
    "appType": "mirakana::GameApp",
    "runner": "mirakana::DesktopGameRunner",
    "currentRuntime": "desktop-windowed-win32-presentation-with-build-output-d3d12-dxil-vulkan-spirv-artifact-validation-and-null-fallback"
  },
  "backendReadiness": {
    "platform": "win32-desktop",
    "graphics": "build-output-d3d12-dxil-with-null-fallback-and-vulkan-spirv-artifact-validation",
    "audio": "device-independent",
    "ui": "mirakana_ui-headless",
    "physics": "not-required"
  },
  "importerRequirements": {
    "sourceFormats": [
      "first-party"
    ],
    "cookedOnlyRuntime": true,
    "externalImportersRequired": []
  },
  "packagingTargets": [
    "desktop-game-runtime",
    "desktop-runtime-release"
  ],
  "validationRecipes": [
    {
      "name": "desktop-game-runtime",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate-desktop-game-runtime.ps1"
    },
    {
      "name": "desktop-runtime-release",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/package-desktop-runtime.ps1"
    },
    {
      "name": "desktop-d3d12-window-smoke",
      "command": "out\\build\\desktop-runtime\\games\\Debug\\sample_desktop_runtime_shell.exe --smoke --require-d3d12-shaders --require-d3d12-renderer"
    },
    {
      "name": "desktop-vulkan-shader-artifact-smoke",
      "command": "out\\build\\desktop-runtime\\games\\Debug\\sample_desktop_runtime_shell.exe --smoke --require-vulkan-shaders"
    }
  ]
}
