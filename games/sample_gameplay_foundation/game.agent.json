{
  "schemaVersion": 1,
  "name": "sample-gameplay-foundation",
  "displayName": "Sample Gameplay Foundation",
  "language": "C++23",
  "entryPoint": "games/sample_gameplay_foundation/main.cpp",
  "target": "sample_gameplay_foundation",
  "engineModules": [
    "MK_core",
    "MK_ai",
    "MK_animation",
    "MK_audio",
    "MK_math",
    "MK_navigation",
    "MK_physics"
  ],
  "aiWorkflow": {
    "spec": "games/sample_gameplay_foundation/README.md",
    "validate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate.ps1",
    "allowedEditRoots": [
      "games/sample_gameplay_foundation",
      "tests"
    ]
  },
  "gameplayContract": {
    "appType": "mirakana::GameApp",
    "runner": "mirakana::HeadlessRunner",
    "physics": "mirakana::PhysicsWorld3D plus build_physics_world_3d_from_authored_collision_scene and move_physics_character_controller_3d",
    "animation": "mirakana::AnimationStateMachine",
    "audio": "mirakana::AudioMixer plus render_audio_device_stream_interleaved_float",
    "navigation": "mirakana::NavigationGrid -> mirakana::plan_navigation_grid_agent_path -> mirakana::update_navigation_agent",
    "ai": "mirakana::build_ai_perception_snapshot_2d -> mirakana::write_ai_perception_blackboard -> mirakana::evaluate_behavior_tree",
    "currentRuntime": "headless runtime systems composition proof"
  },
  "backendReadiness": {
    "platform": "headless",
    "graphics": "null",
    "audio": "device-independent",
    "ui": "mirakana_ui-headless",
    "physics": "first-party-deterministic-authored-collision-controller",
    "navigation": "first-party-deterministic",
    "ai": "behavior-tree-blackboard-perception-services-v1"
  },
  "importerRequirements": {
    "sourceFormats": [
      "first-party"
    ],
    "cookedOnlyRuntime": true,
    "externalImportersRequired": []
  },
  "packagingTargets": [
    "source-tree-default"
  ],
  "validationRecipes": [
    {
      "name": "default",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate.ps1"
    }
  ]
}
