{
  "schemaVersion": 1,
  "name": "sample-generated-desktop-runtime-package",
  "displayName": "sample-generated-desktop-runtime-package",
  "language": "C++23",
  "entryPoint": "games/sample_generated_desktop_runtime_package/main.cpp",
  "target": "sample_generated_desktop_runtime_package",
  "engineModules": [
    "MK_core",
    "MK_math",
    "MK_platform",
    "MK_platform_win32",
    "MK_renderer",
    "MK_runtime_host",
    "MK_runtime_host_win32",
    "MK_runtime_host_win32_presentation"
  ],
  "aiWorkflow": {
    "spec": "games/sample_generated_desktop_runtime_package/README.md",
    "validate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate-desktop-game-runtime.ps1",
    "allowedEditRoots": [
      "games/sample_generated_desktop_runtime_package",
      "tests"
    ]
  },
  "gameplayContract": {
    "appType": "mirakana::GameApp",
    "runner": "mirakana::Win32DesktopGameHost",
    "currentRuntime": "desktop-windowed-win32-host-with-null-renderer-packaged-config-smoke"
  },
  "backendReadiness": {
    "platform": "win32-desktop",
    "graphics": "native-null-renderer; generated scaffold does not create D3D12/Vulkan shader artifacts",
    "audio": "device-independent",
    "ui": "mirakana_ui-headless",
    "physics": "not-required"
  },
  "importerRequirements": {
    "sourceFormats": [
      "first-party"
    ],
    "cookedOnlyRuntime": true,
    "externalImportersRequired": []
  },
  "packagingTargets": [
    "desktop-game-runtime",
    "desktop-runtime-release"
  ],
  "runtimePackageFiles": [
    "runtime/sample_generated_desktop_runtime_package.config"
  ],
  "validationRecipes": [
    {
      "name": "desktop-game-runtime",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate-desktop-game-runtime.ps1"
    },
    {
      "name": "desktop-runtime-release-target",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/package-desktop-runtime.ps1 -GameTarget sample_generated_desktop_runtime_package"
    },
    {
      "name": "installed-config-smoke",
      "command": "out\\install\\desktop-runtime-release\\bin\\sample_generated_desktop_runtime_package.exe --smoke --require-config runtime/sample_generated_desktop_runtime_package.config"
    }
  ]
}
